# NoteSlip 环境变量配置
# 复制此文件为 .env 并填入你的值，然后在 shell 中 source 即可
# PowerShell:  . .env.ps1
# CMD:         不支持 source，请直接 set 变量
# Bash/Zsh:    source .env.sh

# 库根目录路径（省去每次 --vault 参数）
NOTESLIP_VAULT=D:\Vault

# 本机标识：home 或 work（省去 init 时输入 side 参数）
NOTESLIP_SIDE=home

# 导入时默认的分片文件目录（省去 --parts-dir 参数）
NOTESLIP_PARTS_DIR=
